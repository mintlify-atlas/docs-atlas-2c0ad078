  "keyFeatures": [
    "API Gateway for unified entry point and service routing",
    "Reactive microservices using Spring WebFlux and R2DBC",
    "Authentication service with user management",
    "Education service for LMS course/content management",
    "Admin service for platform administration",
    "PostgreSQL databases per microservice (database-per-service pattern)",
    "Docker Compose orchestration for local development",
    "Health check endpoints via Spring Actuator",
    "Hexagonal (Clean) architecture with domain, application, and infrastructure layers"
  ],
  "publicApiSurface": [
    "GET /actuator/health — Health check for all services",
    "GET /actuator/info — Service information",
    "GET /actuator/metrics — Service metrics",
    "api-gateway (port 8080) — Unified API entry point routing to microservices",
    "ms-auth (port 8082) — User authentication and registration",
    "ms-education (port 8081) — Education/course management",
    "ms-admin (port 8083) — Administrative operations",
    "users table — User accounts with username, email, password, name, active status",
    "admin_users table — Admin accounts with role-based access"
  ]
}
